# --- RECIPIENT SETTINGS ---
EMAIL_TO=recipient@example.com
SMTP_DISPLAY_NAME=Your Organization NOC

# --- SMTP / AWS SES SETTINGS ---
# The verified email address in your AWS SES console
SMTP_FROM=sender@example.com

# AWS SES SMTP Endpoint (e.g., email-smtp.eu-central-1.amazonaws.com)
SMTP_HOST=your-smtp-host.amazonaws.com
SMTP_PORT=587

# AWS SES SMTP Credentials (NOT your AWS Access Keys)
SMTP_USER=YOUR_SMTP_USERNAME_HERE
SMTP_PASSWORD=YOUR_SMTP_PASSWORD_HERE
